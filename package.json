{
  "name": "licenseguard",
  "version": "1.0.0",
  "description": "Enterprise-grade dependency license compliance scanner with policy enforcement and automated negotiation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "licenseguard": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "npm run build",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "license",
    "compliance",
    "spdx",
    "dependency",
    "scanner",
    "foss",
    "open-source",
    "governance",
    "policy",
    "gpl",
    "agpl",
    "mit",
    "apache",
    "bsd"
  ],
  "author": "LicenseGuard Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/moggan1337/LicenseGuard"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.3",
    "commander": "^11.1.0",
    "conf": "^10.2.0",
    "dotenv": "^16.3.1",
    "fs-extra": "^11.2.0",
    "graphlib": "^2.1.8",
    "js-yaml": "^4.1.0",
    "node-fetch": "^2.7.0",
    "ora": "^5.4.1",
    "package-json": "^8.1.1",
    "semver": "^7.5.4",
    "spdx-expression-parse": "^3.0.1",
    "spdx-satisfies": "^5.0.1",
    "treeify": "^1.1.0",
    "which": "^4.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.6",
    "@types/node-fetch": "^2.6.9",
    "@types/semver": "^7.5.6",
    "@types/treeify": "^1.0.3",
    "@types/which": "^3.0.3",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
